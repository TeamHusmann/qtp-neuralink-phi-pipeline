# =============================================================================
# Demo with synthetic data
# =============================================================================

def generate_demo_lfp(n_channels=4, duration_sec=2.0, fs=20000, 
                       phi_locked=True, seed=42):
    """
    Generate synthetic LFP with optional φ-locked oscillations.
    
    When phi_locked=True, bands are phase-coupled at the golden ratio
    predicted phase offset (2π/φ²), simulating a lasing cascade state.
    When False, phases are random (non-lasing baseline).
    """
    rng = np.random.default_rng(seed)
    n_samp = int(duration_sec * fs)
    t = np.arange(n_samp) / fs
    lfp = np.zeros((n_channels, n_samp))
    
    for ch in range(n_channels):
        base_phase = rng.uniform(0, 2 * np.pi)
        for i, f in enumerate(FREQS):
            amp = 1.0 / (1 + 0.3 * i)  # gentle rolloff
            if phi_locked:
                # Phase locked at golden ratio offsets
                phase = base_phase + i * (2 * np.pi / phi_sq)
                # Add slight jitter (coherence < 1.0)
                jitter = rng.normal(0, 0.1, n_samp) if ch > 0 else 0
            else:
                phase = rng.uniform(0, 2 * np.pi)
                jitter = rng.normal(0, 0.8, n_samp)
            
            lfp[ch] += amp * np.sin(2 * np.pi * f * t + phase + jitter)
        
        # Add pink noise
        noise = rng.normal(0, 0.3, n_samp)
        lfp[ch] += noise
    
    return lfp


